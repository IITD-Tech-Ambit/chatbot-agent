# ============================================
# Chatbot Agent — Environment Config
# ============================================

# Server
PORT=3003
HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=info

# MongoDB (shared research database)
MONGODB_URI=mongodb://localhost:27017/research_db

# OpenSearch (paper retrieval)
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=research_documents

# Redis (rate limiting + embedding cache + LLM response cache)
REDIS_URL=redis://localhost:6379

# East-west transport: grpc (via Envoy, production) | http (direct, dev)
MESH_TRANSPORT=http
ENVOY_GRPC_TARGET=envoy:10000

# chat.v1 gRPC listener (CheckQuota)
GRPC_ENABLED=true
GRPC_PORT=50054

# Embedding service (BGE) — HTTP fallback when MESH_TRANSPORT=http
EMBEDDING_SERVICE_URL=http://localhost:8000
EMBEDDING_TIMEOUT_MS=10000

# Search API (faculty-for-topic aggregation) — HTTP fallback when MESH_TRANSPORT=http
SEARCH_API_URL=http://localhost:3001

# Per-user daily message quota (IST calendar day). Only categories listed in
# CHAT_QUOTA_LIMITED_CATEGORIES (comma-separated, case-insensitive substring
# match against the IITD OAuth category claim, e.g. "student" also matches
# "UG Student"/"PG Student") are subject to the limit — everyone else
# (faculty, staff, anything unlisted) is unlimited. Comma-separated kerberos
# IDs in CHAT_QUOTA_WHITELIST_KERBEROS bypass the limit regardless of category.
CHAT_QUOTA_DAILY=5
CHAT_QUOTA_LIMITED_CATEGORIES=student
CHAT_QUOTA_WHITELIST_KERBEROS=

# Groq LLM (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
MAX_ANSWER_TOKENS=1024

# Outbound proxy for xAI/Groq calls (e.g. campus proxy), if required to reach
# the internet. Scoped to just this client — deliberately NOT the generic
# HTTP_PROXY/HTTPS_PROXY env vars, which are container-wide and would also
# leak into anything else in the container that auto-honors them (e.g. this
# image's own urllib-based HEALTHCHECK). Leave blank to call api.x.ai directly.
LLM_HTTP_PROXY_URL=

# Agent behaviour
MAX_TOOL_ROUNDS=1
CHAT_TOP_K=8
CHAT_MAX_HISTORY_TURNS=6
CHAT_MAX_MESSAGE_LENGTH=2000
HISTORY_TOKEN_BUDGET=800

# LLM response cache TTL (seconds); 0 = disabled
LLM_CACHE_TTL=90

# Rate limit (per IP)
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=20
